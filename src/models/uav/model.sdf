<?xml version="1.0" ?>
<sdf version="1.8">
  <model name="uav">
    <pose>0 0 0 0 0 0</pose>
    <static>false</static>
    <self_collide>false</self_collide>

    <link name="base_link">
      <pose>0 0 0 0 0 0</pose>
      <inertial><mass>1.2</mass><inertia><ixx>0.02</ixx><iyy>0.02</iyy><izz>0.04</izz></inertia></inertial>
      <collision name="collision"><geometry><sphere><radius>0.18</radius></sphere></geometry></collision>
      <visual name="visual"><geometry><sphere><radius>0.18</radius></sphere></geometry></visual>
      <sensor name="lidar" type="gpu_lidar">
        <pose>0 0 0 0 0 0</pose>
        <topic>lidar</topic>
        <update_rate>15</update_rate>
        <ray><scan><horizontal><samples>180</samples><resolution>1</resolution><min_angle>-3.14159</min_angle><max_angle>3.14159</max_angle></horizontal></scan><range><min>0.2</min><max>15.0</max><resolution>0.01</resolution></range></ray>
        <always_on>1</always_on>
        <visualize>false</visualize>
      </sensor>
    </link>
    <link name="rotor_0"><pose>0.22 0.22 0.05 0 0 0</pose><inertial><mass>0.03</mass><inertia><ixx>1e-5</ixx><iyy>1e-5</iyy><izz>2e-5</izz></inertia></inertial></link>
    <link name="rotor_1"><pose>-0.22 0.22 0.05 0 0 0</pose><inertial><mass>0.03</mass><inertia><ixx>1e-5</ixx><iyy>1e-5</iyy><izz>2e-5</izz></inertia></inertial></link>
    <link name="rotor_2"><pose>-0.22 -0.22 0.05 0 0 0</pose><inertial><mass>0.03</mass><inertia><ixx>1e-5</ixx><iyy>1e-5</iyy><izz>2e-5</izz></inertia></inertial></link>
    <link name="rotor_3"><pose>0.22 -0.22 0.05 0 0 0</pose><inertial><mass>0.03</mass><inertia><ixx>1e-5</ixx><iyy>1e-5</iyy><izz>2e-5</izz></inertia></inertial></link>
    <joint name="rotor_0_joint" type="revolute"><parent>base_link</parent><child>rotor_0</child><axis><xyz>0 0 1</xyz><limit><lower>-1e16</lower><upper>1e16</upper></limit></axis></joint>
    <joint name="rotor_1_joint" type="revolute"><parent>base_link</parent><child>rotor_1</child><axis><xyz>0 0 1</xyz><limit><lower>-1e16</lower><upper>1e16</upper></limit></axis></joint>
    <joint name="rotor_2_joint" type="revolute"><parent>base_link</parent><child>rotor_2</child><axis><xyz>0 0 1</xyz><limit><lower>-1e16</lower><upper>1e16</upper></limit></axis></joint>
    <joint name="rotor_3_joint" type="revolute"><parent>base_link</parent><child>rotor_3</child><axis><xyz>0 0 1</xyz><limit><lower>-1e16</lower><upper>1e16</upper></limit></axis></joint>
  </model>
</sdf>
