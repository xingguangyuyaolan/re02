<?xml version="1.0" ?>
<sdf version="1.8">
  <model name="uav1">
    <pose>0 0 0 0 0 0</pose>
    <static>false</static>
    <self_collide>false</self_collide>

    <link name="base_link">
      <pose>0 0 0 0 0 0</pose>
      <inertial>
        <mass>1.2</mass>
        <inertia>
          <ixx>0.02</ixx>
          <iyy>0.02</iyy>
          <izz>0.04</izz>
        </inertia>
      </inertial>
      <collision name="collision">
        <geometry>
          <sphere>
            <radius>0.18</radius>
          </sphere>
        </geometry>
      </collision>
      <visual name="body_visual">
        <geometry>
          <sphere>
            <radius>0.18</radius>
          </sphere>
        </geometry>
        <material>
          <ambient>0.0 0.2 1.0 1</ambient>
          <diffuse>0.0 0.3 1.0 1</diffuse>
          <emissive>0.0 0.1 0.5 1</emissive>
        </material>
      </visual>
      <sensor name="lidar" type="gpu_lidar">
        <pose>0 0 0 0 0 0</pose>
        <topic>uav1/lidar</topic>
        <update_rate>15</update_rate>
        <ray>
          <scan>
            <horizontal>
              <samples>36</samples>
              <resolution>1</resolution>
              <min_angle>-3.14159</min_angle>
              <max_angle>3.14159</max_angle>
            </horizontal>
          </scan>
          <range>
            <min>0.2</min>
            <max>15.0</max>
            <resolution>0.01</resolution>
          </range>
        </ray>
        <always_on>1</always_on>
        <visualize>false</visualize>
      </sensor>
    </link>

    <link name="rotor_0">
      <pose>0.22 0.22 0.05 0 0 0</pose>
      <inertial>
        <mass>0.03</mass>
        <inertia>
          <ixx>1e-5</ixx>
          <iyy>1e-5</iyy>
          <izz>2e-5</izz>
        </inertia>
      </inertial>
      <visual name="visual">
        <geometry>
          <cylinder>
            <radius>0.08</radius>
            <length>0.01</length>
          </cylinder>
        </geometry>
      </visual>
    </link>
    <link name="rotor_1">
      <pose>-0.22 0.22 0.05 0 0 0</pose>
      <inertial>
        <mass>0.03</mass>
        <inertia>
          <ixx>1e-5</ixx>
          <iyy>1e-5</iyy>
          <izz>2e-5</izz>
        </inertia>
      </inertial>
      <visual name="visual">
        <geometry>
          <cylinder>
            <radius>0.08</radius>
            <length>0.01</length>
          </cylinder>
        </geometry>
      </visual>
    </link>
    <link name="rotor_2">
      <pose>-0.22 -0.22 0.05 0 0 0</pose>
      <inertial>
        <mass>0.03</mass>
        <inertia>
          <ixx>1e-5</ixx>
          <iyy>1e-5</iyy>
          <izz>2e-5</izz>
        </inertia>
      </inertial>
      <visual name="visual">
        <geometry>
          <cylinder>
            <radius>0.08</radius>
            <length>0.01</length>
          </cylinder>
        </geometry>
      </visual>
    </link>
    <link name="rotor_3">
      <pose>0.22 -0.22 0.05 0 0 0</pose>
      <inertial>
        <mass>0.03</mass>
        <inertia>
          <ixx>1e-5</ixx>
          <iyy>1e-5</iyy>
          <izz>2e-5</izz>
        </inertia>
      </inertial>
      <visual name="visual">
        <geometry>
          <cylinder>
            <radius>0.08</radius>
            <length>0.01</length>
          </cylinder>
        </geometry>
      </visual>
    </link>

    <joint name="rotor_0_joint" type="revolute">
      <parent>base_link</parent>
      <child>rotor_0</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
        </limit>
      </axis>
    </joint>
    <joint name="rotor_1_joint" type="revolute">
      <parent>base_link</parent>
      <child>rotor_1</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
        </limit>
      </axis>
    </joint>
    <joint name="rotor_2_joint" type="revolute">
      <parent>base_link</parent>
      <child>rotor_2</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
        </limit>
      </axis>
    </joint>
    <joint name="rotor_3_joint" type="revolute">
      <parent>base_link</parent>
      <child>rotor_3</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
        </limit>
      </axis>
    </joint>

    <plugin filename="gz-sim-multicopter-motor-model-system" name="gz::sim::systems::MulticopterMotorModel">
      <robotNamespace>uav1</robotNamespace>
      <jointName>rotor_0_joint</jointName>
      <linkName>rotor_0</linkName>
      <turningDirection>ccw</turningDirection>
      <timeConstantUp>0.0182</timeConstantUp>
      <timeConstantDown>0.0182</timeConstantDown>
      <maxRotVelocity>1000.0</maxRotVelocity>
      <motorConstant>1.269e-05</motorConstant>
      <momentConstant>0.016754</momentConstant>
      <commandSubTopic>command/motor_speed</commandSubTopic>
      <actuator_number>0</actuator_number>
      <rotorDragCoefficient>2.0673e-04</rotorDragCoefficient>
      <rollingMomentCoefficient>0</rollingMomentCoefficient>
      <motorSpeedPubTopic>motor_speed/0</motorSpeedPubTopic>
      <rotorVelocitySlowdownSim>2</rotorVelocitySlowdownSim>
      <motorType>velocity</motorType>
    </plugin>
    <plugin filename="gz-sim-multicopter-motor-model-system" name="gz::sim::systems::MulticopterMotorModel">
      <robotNamespace>uav1</robotNamespace>
      <jointName>rotor_1_joint</jointName>
      <linkName>rotor_1</linkName>
      <turningDirection>cw</turningDirection>
      <timeConstantUp>0.0182</timeConstantUp>
      <timeConstantDown>0.0182</timeConstantDown>
      <maxRotVelocity>1000.0</maxRotVelocity>
      <motorConstant>1.269e-05</motorConstant>
      <momentConstant>0.016754</momentConstant>
      <commandSubTopic>command/motor_speed</commandSubTopic>
      <actuator_number>1</actuator_number>
      <rotorDragCoefficient>2.0673e-04</rotorDragCoefficient>
      <rollingMomentCoefficient>0</rollingMomentCoefficient>
      <motorSpeedPubTopic>motor_speed/1</motorSpeedPubTopic>
      <rotorVelocitySlowdownSim>2</rotorVelocitySlowdownSim>
      <motorType>velocity</motorType>
    </plugin>
    <plugin filename="gz-sim-multicopter-motor-model-system" name="gz::sim::systems::MulticopterMotorModel">
      <robotNamespace>uav1</robotNamespace>
      <jointName>rotor_2_joint</jointName>
      <linkName>rotor_2</linkName>
      <turningDirection>ccw</turningDirection>
      <timeConstantUp>0.0182</timeConstantUp>
      <timeConstantDown>0.0182</timeConstantDown>
      <maxRotVelocity>1000.0</maxRotVelocity>
      <motorConstant>1.269e-05</motorConstant>
      <momentConstant>0.016754</momentConstant>
      <commandSubTopic>command/motor_speed</commandSubTopic>
      <actuator_number>2</actuator_number>
      <rotorDragCoefficient>2.0673e-04</rotorDragCoefficient>
      <rollingMomentCoefficient>0</rollingMomentCoefficient>
      <motorSpeedPubTopic>motor_speed/2</motorSpeedPubTopic>
      <rotorVelocitySlowdownSim>2</rotorVelocitySlowdownSim>
      <motorType>velocity</motorType>
    </plugin>
    <plugin filename="gz-sim-multicopter-motor-model-system" name="gz::sim::systems::MulticopterMotorModel">
      <robotNamespace>uav1</robotNamespace>
      <jointName>rotor_3_joint</jointName>
      <linkName>rotor_3</linkName>
      <turningDirection>cw</turningDirection>
      <timeConstantUp>0.0182</timeConstantUp>
      <timeConstantDown>0.0182</timeConstantDown>
      <maxRotVelocity>1000.0</maxRotVelocity>
      <motorConstant>1.269e-05</motorConstant>
      <momentConstant>0.016754</momentConstant>
      <commandSubTopic>command/motor_speed</commandSubTopic>
      <actuator_number>3</actuator_number>
      <rotorDragCoefficient>2.0673e-04</rotorDragCoefficient>
      <rollingMomentCoefficient>0</rollingMomentCoefficient>
      <motorSpeedPubTopic>motor_speed/3</motorSpeedPubTopic>
      <rotorVelocitySlowdownSim>2</rotorVelocitySlowdownSim>
      <motorType>velocity</motorType>
    </plugin>
    <plugin filename="gz-sim-multicopter-control-system" name="gz::sim::systems::MulticopterVelocityControl">
      <robotNamespace>uav1</robotNamespace>
      <commandSubTopic>cmd_vel</commandSubTopic>
      <comLinkName>base_link</comLinkName>
      <velocityGain>2.7 2.7 2.9</velocityGain>
      <attitudeGain>2 2 0.2</attitudeGain>
      <angularRateGain>0.4 0.45 0.18</angularRateGain>
      <maximumLinearAcceleration>2.5 2.5 2.0</maximumLinearAcceleration>
      <rotorConfiguration>
        <rotor>
          <jointName>rotor_0_joint</jointName>
          <forceConstant>1.269e-05</forceConstant>
          <momentConstant>0.016754</momentConstant>
          <direction>1</direction>
        </rotor>
        <rotor>
          <jointName>rotor_1_joint</jointName>
          <forceConstant>1.269e-05</forceConstant>
          <momentConstant>0.016754</momentConstant>
          <direction>-1</direction>
        </rotor>
        <rotor>
          <jointName>rotor_2_joint</jointName>
          <forceConstant>1.269e-05</forceConstant>
          <momentConstant>0.016754</momentConstant>
          <direction>1</direction>
        </rotor>
        <rotor>
          <jointName>rotor_3_joint</jointName>
          <forceConstant>1.269e-05</forceConstant>
          <momentConstant>0.016754</momentConstant>
          <direction>-1</direction>
        </rotor>
      </rotorConfiguration>
    </plugin>
    <plugin filename="gz-sim-odometry-publisher-system" name="gz::sim::systems::OdometryPublisher">
      <dimensions>3</dimensions>
    </plugin>
  </model>
</sdf>
