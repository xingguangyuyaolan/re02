{
  "episodes": 600,
  "max_steps": 1000,
  "seed": 7,
  "world_name": "maze_1.sdf",
  "arena_x_limits": [-10.0, 10.0],
  "arena_y_limits": [-10.0, 10.0],

  "coverage_cell_size": 0.5,
