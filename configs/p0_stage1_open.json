  "action_update_timeout": 0.02,
  "require_step_lidar_update": false,

  "batch_size": 8,
  "lr": 0.0004,
  "gamma": 0.99,
  "epsilon": 1.0,
  "epsilon_min": 0.05,
  "epsilon_decay_steps": 156800,
  "early_stop_enabled": true,
  "early_stop_min_episodes": 120,
