  "hyper_layers_num": 2,

  "diagnostics_interval": 25,
  "output_root": "artifacts/qmix",
  "run_name": "p0_stage1_open_seed7",
  "checkpoint_interval": 25,
  "save_best": true,

  "use_self_attention": true,
  "self_attn_heads": 4,
  "self_attn_tokens": 4,
  "use_cross_agent_attention": true,
