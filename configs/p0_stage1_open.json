{
  "episodes": 280,
  "max_steps": 800,
  "seed": 7,
  "world_name": "stage_1_open.sdf",
  "arena_x_limits": [-10.0, 10.0],
  "arena_y_limits": [-10.0, 10.0],

  "coverage_cell_size": 1.0,
  "coverage_target_ratio": 0.5,
  "coverage_new_cell_reward": 0.45,
  "coverage_completion_bonus": 18.0,
  "revisit_cell_penalty": 0.18,
  "overlap_cell_penalty": 0.25,
  "assignment_bonus": 0.08,
  "local_coverage_radius": 2,
  "sensor_coverage_radius": 1,
  "local_map_size": 7,
  "coverage_delta_scale": 45.0,

  "startup_grace_steps": 90,
  "min_height_enforce_steps": 80,
  "hard_floor_height": 0.08,
  "out_of_bounds_penalty": 6.0,
  "min_step_duration": 0.05,
  "altitude_safety_threshold": 0.4,
  "low_altitude_penalty": 0.3,
  "collision_penalty": 2.2,
  "collision_terminal": false,
  "collision_cooldown_steps": 10,
  "survival_bonus": 0.015,
  "boundary_penalty_margin": 2.5,
  "boundary_penalty_scale": 0.45,

  "reset_timeout": 5.0,
  "reset_position_tolerance": 5,
  "reset_stabilization_timeout": 1.5,
  "reset_poll_interval": 0.05,
  "reset_initial_sensor_timeout": 1.2,
  "reset_initial_sensor_timeout_first": 3.0,
