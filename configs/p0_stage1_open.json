  "early_stop_patience_windows": 3,
  "early_stop_min_delta": 2.5,
  "early_stop_success_threshold": 0.48,
  "early_stop_oob_threshold": 0.72,
  "early_stop_fail_oob_threshold": 0.93,
  "early_stop_fail_patience_windows": 4,
  "train_interval": 2,
  "obs_clip": 20.0,
  "q_clip": 100.0,
  "td_clip": 50.0,
  "grad_clip_norm": 10.0,

  "rnn_hidden_dim": 128,
  "buffer_size": 5000,
  "target_update_freq": 200,
  "qmix_hidden_dim": 64,
